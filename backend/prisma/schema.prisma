// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  engineType = "binary"
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum FriendshipStatus {
  pending
  accepted
  blocked
}

enum UserStatus {
  online
  playing
  away
  offline
}

enum PlayerColor {
  RED
  GREEN
  YELLOW
  BLUE
}

enum GameStatus {
  COMPLETED
  ABANDONED
}

enum GameType {
  PVP
  PVE
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id            String       @id
  username      String       @unique
  password_hash String
  rating        Int          @default(0)
  highestRating Int          @default(0)
  rankedWins    Int          @default(0)
  rankedLosses  Int          @default(0)
  rankedDraws   Int          @default(0)
  winStreak     Int          @default(0)
  bestWinStreak Int          @default(0)
  botWins       Int          @default(0)
  humanWins     Int          @default(0)
  lastLoginAt   DateTime?
  loginStreak   Int          @default(0)
  daysActive    Int          @default(0)
  totalPlayTimeMs Int        @default(0)
  avatarStyle   String        @default("bottts")
  avatarPhoto   Bytes?
  avatarPhotoContentType String?
  status        UserStatus   @default(offline)
  isOnline      Boolean      @default(false)
  disconnectCount Int        @default(0)
  reconnectCount  Int        @default(0)

  // Achievement booleans
  achFirstBlood        Boolean @default(false)
  achOnFire            Boolean @default(false)
  achDiceMaster        Boolean @default(false)
  achBabySteps         Boolean @default(false)
  achTheDiceLoveMe     Boolean @default(false)
  achTactician         Boolean @default(false)
  achMaster            Boolean @default(false)
  achGrandBotMaster    Boolean @default(false)
  achWorldChampion     Boolean @default(false)
  achLoveTheMachine    Boolean @default(false)
  achft_Transcendence  Boolean @default(false)
  achSpeedDemon        Boolean @default(false)
  achUnstoppable       Boolean @default(false)
  achCleanSweep        Boolean @default(false)
  achLastLaugh         Boolean @default(false)

  // Ludo result detail counters
  gamesWithFourPieces  Int  @default(0)
  gamesWithThreePieces Int  @default(0)
  gamesWithTwoPieces   Int  @default(0)
  gamesWithOnePiece    Int  @default(0)
  gamesWithZeroPieces  Int  @default(0)

  gameParticipants GameParticipant[]
  sentFriendships     Friendship[] @relation("SentFriendships")
  receivedFriendships Friendship[] @relation("ReceivedFriendships")

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// ─── Game (historical results only — matchmaking lives in Redis) ─────────────

model Game {
  id              String       @id
  startedAt       DateTime
  endedAt         DateTime
  durationSeconds Int          @default(0)
  status          GameStatus   @default(COMPLETED)
  gameType        GameType     @default(PVP)
  inviteCode      String?      @unique

  participants GameParticipant[]
}

model GameParticipant {
  id              String      @id
  game_id         String
  user_id         String
  color           PlayerColor
  rank            Int         // 1st, 2nd, 3rd, 4th place
  totalTurns      Int         @default(0)
  piecesCaptured  Int         @default(0)
  piecesInGoal    Int         @default(0)  // 0-4

  game  Game  @relation(fields: [game_id], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([game_id, user_id])
}

// ─── Friendship ──────────────────────────────────────────────────────────────

model Friendship {
  id        String          @id
  userId    String
  friendId  String
  status    FriendshipStatus @default(pending)
  createdAt DateTime        @default(now())

  user   User @relation("SentFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("ReceivedFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}