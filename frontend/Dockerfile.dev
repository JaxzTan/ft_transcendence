# Dev-only image: long-running Vite server with HMR, used by the frontend-dev
# compose service (profile: dev). The production path is Dockerfile + nginx/;
# nothing here is part of a release build.
# ═══════════════════════════════════════════════════════════

FROM node:22-alpine
WORKDIR /app

# Deps are baked into the image; source arrives as a bind mount at runtime, so
# an anonymous volume keeps /app/node_modules from being shadowed by the host.
COPY package*.json ./
RUN npm install

EXPOSE 8080

CMD ["npm", "run", "dev"]
